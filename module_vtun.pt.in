PTVERSION           = 2
NAME                = @PACKAGE@
VERSION             = @PACKAGE_VERSION@
DESCRIPTION         = robotkernel vtun module
DOCUMENTATION       = doc/README
MAINTAINER          = Florian Schmidt <florian.schmidt@dlr.de>
