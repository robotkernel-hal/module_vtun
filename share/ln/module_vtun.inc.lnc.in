requires_version 0.2.43
# this include file can be customized with the following defines:
#   module_vtun_base
#     (optional) path to module_vtun base directory
#     e.g. /volume/software/robotkernel/packages/module_vtun/3.0.1
#     defaults to rmpm structure
#   module_vtun_libdir
#     (optional) add custom module search paths
# rk_depends: interface_process_data_inspection

defines
module_vtun_base:          %(dirname %(dirname %(CURDIR)))
module_vtun_libdir:        %(subst "${exec_prefix}/", "", "@libdir@")
module_vtun_type:          %(ifexists "%(module_vtun_base)/%(module_vtun_libdir)/libmodule_vtun.so", "local_install", "rmpm_release")
module_vtun_library_path:  %(ifeq "%(module_vtun_type)", "local_install", "%(module_vtun_base)/%(module_vtun_libdir)", "%(module_vtun_base)/lib/$(ARCH)")

ifndef rk_library_path: rk_library_path: ""
rk_library_path: %(rk_library_path):%(module_vtun_library_path)

