log_level: verbose

modules:
  - name: intfA
    so_file: libmodule_vtun.so
    power_up: op
    config:
      prio: 60
      affinity: 1
      write_to: intfB.vtun.stream
    
  - name: intfB
    so_file: libmodule_vtun.so
    power_up: op
    config:
      prio: 60
      affinity: 1
      write_to: intfA.vtun.stream
