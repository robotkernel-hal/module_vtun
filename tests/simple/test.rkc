log_level: debug

modules:
  - name: intfA
    module_file: libmodule_vtun.so
    power_up: true
    config:
      prio: 60
      affinity: 1
      write_to: intfB
    
  - name: intfB
    module_file: libmodule_vtun.so
    power_up: true
    config:
      prio: 60
      affinity: 1
      write_to: intfA
